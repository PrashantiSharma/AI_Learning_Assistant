generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id              String             @id @default(cuid())
  name            String
  email           String             @unique
  passwordHash    String?
  dailyStudyHours Float?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  studyLogs       StudyLog[]
  subjects        Subject[]
  studyPlans      StudyPlan[]
  messages        AssistantMessage[]
  sessions        AuthSession[]
  quizAttempts    TopicQuizAttempt[]
}

model Subject {
  id          String   @id @default(cuid())
  name        String
  studentId   String
  syllabus    String?
  examPattern String?
  examDate    DateTime?
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topics      Topic[]
  createdAt   DateTime @default(now())
}

model Topic {
  id                 String   @id @default(cuid())
  subjectId          String
  name               String
  difficulty         Int?
  completionRatio    Float?   @default(0)
  quizAccuracy       Float?
  practiceAttempts   Int?     @default(0)
  revisionCount      Int?     @default(0)
  previousScore      Float?
  lastStudiedDays    Int?
  predictedPriority  String?
  priorityConfidence Float?
  allocatedHours     Float?
  subject            Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  quizAttempts       TopicQuizAttempt[]
  createdAt          DateTime @default(now())
}

model StudyLog {
  id        String   @id @default(cuid())
  studentId String
  subjectId String?
  topicId   String?
  minutes   Int
  activity  String
  loggedAt  DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudyPlan {
  id          String   @id @default(cuid())
  studentId   String
  title       String
  planDate    DateTime
  contentJson Json
  createdAt   DateTime @default(now())
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model AssistantMessage {
  id        String   @id @default(cuid())
  studentId String
  role      String
  content   String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model AuthSession {
  id        String   @id @default(cuid())
  studentId String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([expiresAt])
}

model TopicQuizAttempt {
  id             String   @id @default(cuid())
  studentId      String
  topicId        String
  status         String   @default("generated")
  totalQuestions Int      @default(10)
  score          Int?
  accuracy       Float?
  questionsJson  Json
  answersJson    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topic          Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([studentId, topicId, createdAt])
}
