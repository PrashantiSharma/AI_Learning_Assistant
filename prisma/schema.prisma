generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id              String             @id @default(cuid())
  name            String
  email           String             @unique
  dailyStudyHours Float?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  studyLogs       StudyLog[]
  subjects        Subject[]
  studyPlans      StudyPlan[]
  messages        AssistantMessage[]
}

model Subject {
  id          String   @id @default(cuid())
  name        String
  studentId   String
  syllabus    String?
  examPattern String?
  examDate    DateTime?
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topics      Topic[]
  createdAt   DateTime @default(now())
}

model Topic {
  id                 String   @id @default(cuid())
  subjectId          String
  name               String
  difficulty         Int?
  completionRatio    Float?   @default(0)
  quizAccuracy       Float?
  practiceAttempts   Int?     @default(0)
  revisionCount      Int?     @default(0)
  previousScore      Float?
  lastStudiedDays    Int?
  predictedPriority  String?
  priorityConfidence Float?
  allocatedHours     Float?
  subject            Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
}

model StudyLog {
  id        String   @id @default(cuid())
  studentId String
  subjectId String?
  topicId   String?
  minutes   Int
  activity  String
  loggedAt  DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudyPlan {
  id          String   @id @default(cuid())
  studentId   String
  title       String
  planDate    DateTime
  contentJson Json
  createdAt   DateTime @default(now())
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model AssistantMessage {
  id        String   @id @default(cuid())
  studentId String
  role      String
  content   String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}
